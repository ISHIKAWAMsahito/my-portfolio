---
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import Header from '../../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../../consts';
---

<!doctype html>
<html lang="ja">
	<head>
		<meta charset="utf-8" />
		<BaseHead title={`Security Report | ${SITE_TITLE}`} description="Snykによる脆弱性診断結果" />
	</head>
	<body>
		<Header />
		<main>
			<section style="margin-top: 2rem; border: 1px solid #444; padding: 1.5rem; border-radius: 8px;">
				<h2 style="margin-top: 0;">🛡️ セキュリティと品質への取り組み</h2>
				<p style="font-size: 0.95rem; line-height: 1.6;">
					本プロジェクトでは、安全なシステム運用のために <strong>Snyk</strong> による脆弱性診断を導入しています。
					静的解析によるソースコードの脆弱性確認および、ライブラリの依存関係チェックを実施し、
					重大なセキュリティリスクが存在しないことを確認しています。
				</p>
					<div style="display: flex; gap: 1.5rem; flex-wrap: wrap; margin-top: 1.5rem;">
					<div style="flex: 1; min-width: 280px;">
						<p style="font-size: 0.85rem; color: #888; margin-bottom: 0.5rem;">▼ コード解析結果</p>
						<img src="/images/snyk-code.png" alt="Snykコード診断結果: 問題なし" style="width: 100%; border-radius: 6px; border: 1px solid #ddd;" />
					</div>
					<div style="flex: 1; min-width: 280px;">
						<p style="font-size: 0.85rem; color: #888; margin-bottom: 0.5rem;">▼ ライブラリ解析結果</p>
						<img src="/images/snyk-lib.png" alt="Snykライブラリ診断結果: 問題なし" style="width: 100%; border-radius: 6px; border: 1px solid #ddd;" />
					</div>
				</div>
				</div>
			</section>
		</main>
		<Footer />
	</body>
</html>