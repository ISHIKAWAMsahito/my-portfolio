---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';

// ここにログイン判定ロジックを書きます（まずは動作確認のため false に設定）
const isLoggedIn = false;
---

<!doctype html>
<html lang="ja">
	<head>
		<meta charset="utf-8" />
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
		<main>
			<h1>👋 こんにちは！ <br />石川雅人です</h1>
			<p>
				私のポートフォリオサイトへようこそ。
				現在はFastAPIを使って、AIチャットボットを開発しています。
			</p>

			<p>
				このサイトでは、私がこれまでに学んだ技術や、作成したプロジェクトを紹介していきます。
			</p>

			<section style="margin-top: 2rem; border: 1px solid #444; padding: 1rem; border-radius: 8px;">
				<h3>AIチャットボット・デモ</h3>
				
				{isLoggedIn ? (
					/* ログインしている場合：チャット画面を表示 */
					<iframe 
						src="http://localhost:8000/static/client.html" 
						style="width: 100%; height: 400px; border: none;"
						title="AI Chatbot"
					></iframe>
				) : (
					/* ログインしていない場合：案内メッセージを表示 */
					<div style="background: #f4f4f4; padding: 2rem; text-align: center; border-radius: 8px; color: #333;">
						<p>⚠️ セキュリティとAPIコスト保護のため、<br />デモの利用にはログインが必要です。</p>
						<a href="http://localhost:8000/login" style="display: inline-block; margin-top: 1rem; background: #000; color: #fff; padding: 0.8rem 1.5rem; text-decoration: none; border-radius: 5px; font-weight: bold;">
							管理者としてログインして試す
						</a>
					</div>
				)}
			</section>
		</main>
		<Footer />
	</body>
</html>